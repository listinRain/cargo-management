# ===== 数据库 =====
# 生产环境（Supabase PostgreSQL）:
DATABASE_URL="postgresql://postgres.xxx:password@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres"
# 本地开发（SQLite，需同时把 schema.prisma 的 provider 改回 "sqlite"）:
# DATABASE_URL="file:./dev.db"

# ===== NextAuth =====
# 部署到 Vercel 后改为 https://你的项目名.vercel.app
NEXTAUTH_SECRET="换成一个随机长字符串至少32个字符"
NEXTAUTH_URL="http://localhost:3000"
